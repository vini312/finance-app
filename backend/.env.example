# ─────────────────────────────────────────────────────────────────────────────
# FinanceFlow Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/financeflow
# Docker: mongodb://mongo:27017/financeflow
# Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/financeflow
MONGODB_URI=mongodb://localhost:27017/financeflow

# HTTP port the Express server listens on
PORT=3001
